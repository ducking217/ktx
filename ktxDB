-- ============================================================
-- 22. CAUHINH — Cấu hình hệ thống (key-value)
-- FIX: thêm nhom để load theo nhóm, tránh load cả bảng
-- ============================================================
CREATE TABLE `cauhinh` (
  `id`         bigint UNSIGNED NOT NULL AUTO_INCREMENT,
  `ten`        varchar(100)    NOT NULL COMMENT 'Key: phi_dich_vu, don_gia_dien...',
  `giatri`     text            DEFAULT NULL COMMENT 'Value dạng string',
  `nhom`       enum('pricing','system','contact') NOT NULL DEFAULT 'system'
               COMMENT 'Nhóm để cache theo nhóm',
  `mo_ta`      varchar(255)    DEFAULT NULL COMMENT 'Mô tả human-readable',
  `created_at` timestamp       NULL DEFAULT NULL,
  `updated_at` timestamp       NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `cauhinh_ten_unique` (`ten`),
  KEY `cauhinh_nhom_index` (`nhom`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
  COMMENT='Cấu hình hệ thống — cache theo nhóm';

-- ============================================================
-- 23. NHAT_KY — Audit log (mọi thao tác quan trọng)
-- ============================================================
CREATE TABLE `nhat_ky` (
  `id`          bigint UNSIGNED NOT NULL AUTO_INCREMENT,
  `user_id`     bigint UNSIGNED DEFAULT NULL COMMENT 'NULL nếu system/scheduler',
  `hanh_dong`   enum('create','update','delete','restore','login','logout')
                NOT NULL,
  `ten_model`   varchar(100)    NOT NULL COMMENT 'Tên Model: Hopdong, Hoadon...',
  `id_ban_ghi`  bigint UNSIGNED NOT NULL,
  `du_lieu_cu`  json            DEFAULT NULL,
  `du_lieu_moi` json            DEFAULT NULL,
  `ip_address`  varchar(45)     DEFAULT NULL,
  `created_at`  timestamp       NULL DEFAULT NULL,
  `updated_at`  timestamp       NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `nhat_ky_user_id_foreign` (`user_id`),
  KEY `nhat_ky_ten_model_index` (`ten_model`),
  KEY `nhat_ky_created_at_index` (`created_at`),
  KEY `nhat_ky_user_created_index` (`user_id`, `created_at`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
  COMMENT='Audit trail — mọi thao tác có thể truy vết';

